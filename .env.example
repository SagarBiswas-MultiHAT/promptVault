# Environment configuration for PromptVault
# Copy this file to .env and fill in your values.

# --- AI Provider Keys ---
# API keys are used only by the Express proxy server and never exposed to the client.
# At least one provider must be configured for the AI Librarian to function.

GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
GEMINI_MODEL="gemini-2.0-flash"

GROQ_API_KEY="YOUR_GROQ_API_KEY"
GROQ_MODEL="llama-3.3-70b-versatile"

# --- Server ---
# Port for the API proxy server (also serves the frontend in production).
AI_PROXY_PORT="3002"

# --- Supabase Auth + Sync ---
# Vite exposes VITE_* variables to the client bundle.
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# --- Production ---
# Set to "production" when deploying. Enables static file serving, HSTS, and stricter validation.
# NODE_ENV="production"

# Comma-separated list of allowed CORS origins in production.
# Leave empty to allow all origins (not recommended for production).
# ALLOWED_ORIGINS="https://promptvault.app,https://www.promptvault.app"
